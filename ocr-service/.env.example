# OCR Service Environment Configuration

# Server Configuration
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Model Configuration
MODEL_PATH=./models/model.onnx

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Performance Tuning
# CPU_THREADS=4  # Number of CPU threads for ONNX Runtime (default: all available)

# File Upload Limits
# MAX_FILE_SIZE=52428800  # 50MB in bytes
